{
  "name": "ribaunt",
  "version": "0.1.6",
  "description": "A PoW CAPTCHA library that provides stateless and secure user verification",
  "homepage": "https://ribaunt.com",
  "bugs": {
    "url": "https://github.com/ribaunt/ribaunt/issues"
  },
  "main": "dist/cjs/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./widget": {
      "client": "./dist/widget-browser.js",
      "default": "./dist/widget-browser.js",
      "types": "./dist/widget-browser.d.ts"
    },
    "./widget-react": {
      "client": "./dist/widget-react.js",
      "default": "./dist/widget-react.js",
      "types": "./dist/widget-react.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ribaunt/ribaunt.git"
  },
  "license": "GPL-3.0-only",
  "author": "ribaunt",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc --project tsconfig.cjs.json && node scripts/prepare-cjs.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.2.3",
    "jsdom": "^27.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2"
  }
}
